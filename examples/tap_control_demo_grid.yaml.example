# This file configures the tap-control demo only.
#
# It is not the central Sparlectra configuration file.
#
# Central solver/output/control-framework settings come from:
#   examples/configuration.yaml
#   SPARLECTRA_CONFIGURATION_YAML
#   load_sparlectra_config() discovery
#
# This demo YAML defines example setpoints and tap/phase ranges for:
#   - OLTC (`oltc`)
#   - PST (`pst`)
#   - Schrägregler (`schraeg`)
#
# Controller objects are created programmatically by the demo script.
# This file is not the central control.controllers schema.

# Optional path to central Sparlectra config.
# Relative paths are resolved relative to this demo YAML file.
# sparlectra_config: configuration.yaml

oltc:
  target_bus: Load_LV
  target_vm_pu: 0.995
  deadband_vm_pu: 0.02
  max_outer_iters: 12
  tap_min: 0.95
  tap_max: 1.08
  tap_step: 0.0125

pst:
  target_branch_from: Grid_B
  target_branch_to: MV_B
  p_target_mw: -53.0
  deadband_p_mw: 8.0
  max_outer_iters: 12
  phase_min_deg: -15.0
  phase_max_deg: 15.0
  phase_step_deg: 1.0

schraeg:
  target_bus: Load_MV
  target_vm_pu: 0.99
  target_branch_from: MV_A
  target_branch_to: MV_B
  p_target_mw: 8.5
  deadband_vm_pu: 0.02
  deadband_p_mw: 8.0
  max_outer_iters: 20
  tap_min: 0.95
  tap_max: 1.08
  tap_step: 0.0125
  phase_min_deg: -10.0
  phase_max_deg: 10.0
  phase_step_deg: 1.0
