# This file configures the tap-control demo only.
#
# It is not the central Sparlectra configuration file.
#
# Central solver/output/control-framework settings come from:
#   examples/configuration.yaml
# or:
#   SPARLECTRA_CONFIGURATION_YAML
# or an optional sparlectra_config path in this demo YAML.
#
# This demo YAML provides controller setpoints and transformer tap parameters
# used by the example script to create controllers programmatically.
#
# It is not the same as control.controllers in src/configuration.yaml.example.
#
# Recommended local workflow (git-clean):
#   cp examples/tap_control_demo_grid.yaml.example examples/tap_control_demo_grid.yaml
#   # edit examples/tap_control_demo_grid.yaml (this file is git-ignored)

# Optional path to central Sparlectra config.
# If omitted, the normal Sparlectra config discovery is used.
# Relative paths are resolved relative to this demo YAML file.
# sparlectra_config: configuration.yaml

controller:
  target_bus: Load
  target_vm_pu: 0.98
  deadband_vm_pu: 0.005
  max_outer_iters: 8

tap:
  tap_min: 0.95
  tap_max: 1.05
  tap_step: 0.0125
