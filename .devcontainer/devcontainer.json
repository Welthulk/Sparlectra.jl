{
    "name": "Sparlectra Julia",
    "image": "julia:1.11",
    "postCreateCommand": "julia --project=. -e 'using Pkg; Pkg.instantiate(); Pkg.precompile()'",
    "customizations": {
        "vscode": {
            "extensions": [
                "julialang.language-julia"
            ]
        }
    },
    "remoteEnv": {
        "JULIA_PROJECT": "${containerWorkspaceFolder}"
    }
}