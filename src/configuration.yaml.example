# Sparlectra central default configuration.
#
# Copy this file to examples/configuration.yaml for local user overrides.
# The local override file is intentionally ignored by Git.

power_flow:
  # Allowed values: rectangular
  # Rectangular is the supported public AC power-flow path.
  method: rectangular
  # Legacy start switch (true = synthetic flat start). Keep aligned with start_mode below.
  flatstart: true
  # Positive solver tolerance and iteration cap.
  tol: 1.0e-5
  max_iter: 80
  # Automatic damping for difficult cases.
  autodamp: true
  autodamp_min: 0.05
  # Wrong-branch plausibility checks after numerical convergence.
  # Allowed values: off, warn, fail, rescue
  wrong_branch_detection: warn
  # Modes:
  # - off: disable post-convergence plausibility checks
  # - warn: keep converged PF result, but report suspicious branch-quality metadata
  # - fail: treat suspicious converged result as PF failure
  # - rescue: reserved mode; currently reports "rescue requested but not available"
  #   and does not run retry attempts yet
  wrong_branch_rescue: false
  wrong_branch_min_vm_pu: 0.70
  wrong_branch_max_vm_pu: 1.30
  wrong_branch_max_angle_spread_deg: 180.0
  # Maximum allowed absolute angle difference across active branches (degrees).
  wrong_branch_max_branch_angle_deg: 90.0
  wrong_branch_min_low_vm_count: 1
  wrong_branch_rescue_max_attempts: 2

  # Rectangular workspace handling.
  rectangular_workspace_reuse: true
  # Allowed values: off, on, auto
  rectangular_preallocate_workspace: auto
  rectangular_workspace_min_buses: 1000

  # Start projection and warmstart controls.
  start_mode:
    # Allowed values: classic, dc, bus_va_blend, matpower_va
    angle_mode: dc
    # Allowed values: classic, pv_gen_vg, pv_bus_vm, all_bus_vm, profile_blend, bus_vm_va_blend
    # Note: bus_vm_va_blend is accepted as a legacy alias and mapped internally.
    voltage_mode: profile_blend
    # Allowed values: flat, dc, bus_metadata, historical_profile, matpower_reference, state_estimation, scada_snapshot
    profile_source: matpower_reference
    # Enable projection-based candidate selection instead of direct start.
    start_projection: true
    # Try a DC-angle candidate start.
    try_dc_start: true
    # Scan blend_lambdas as additional candidates.
    try_blend_scan: true
    # Apply branch sanity checks to candidate starts.
    branch_guard: true
    # Measure/score candidate starts before selection.
    measure_candidates: true
    # Accept DC start even without candidate measurements.
    accept_unmeasured_dc_start: false
    # Reuse imported MATPOWER reference values during start generation.
    reuse_import_data: true
    # Candidate blend factors used when try_blend_scan=true.
    blend_lambdas: [0.25, 0.5, 0.75]
    # Positive DC-angle clamp in degrees.
    dc_angle_limit_deg: 60.0

  # Reactive-power limit switching.
  qlimits:
    enabled: true
    # First iteration where Q-limit switching is allowed.
    start_iter: 3
    # Allowed values: iteration, auto, iteration_or_auto
    start_mode: iteration_or_auto
    auto_q_delta_pu: 1.0e-4
    hysteresis_pu: 0.01
    cooldown_iters: 1
    # Optional bus-id filters for focused diagnostics/policies.
    trace_buses: []
    lock_pv_to_pq_buses: []
    guard:
      enabled: true
      min_q_range_pu: 0.02
      # Allowed values: prefer_pq, lock_pq
      narrow_range_mode: lock_pq
      # Allowed values: lock_pq
      zero_range_mode: lock_pq
      # Allowed values: delayed_switch, lock_pq
      violation_mode: lock_pq
      violation_threshold_pu: 1.0e-4
      max_switches: 3
      max_remaining_violations: 0
      accept_bounded_violations: false
      freeze_after_repeated_switching: true
      log: true

state_estimation:
  enabled: true
  # Allowed values: wls
  method: wls
  tol: 1.0e-8
  max_iter: 20
  # Flat start for state-estimation initialization.
  flatstart: true
  jac_eps: 1.0e-6
  update_net: true
  observability:
    enabled: true

matpower_import:
  # MATPOWER case filename/path resolved by single-case runner paths.
  case: case14.m
  # Ordered batch list for run_sparlectra_cases; non-empty cases take precedence over case.
  cases: [case14.m, case118.m]
  # Allowed values: off, recommend, apply
  # recommend prints a pre-run table without changing the active run.
  # apply may change only convention settings with clear residual evidence;
  # user YAML files are never rewritten.
  auto_profile: recommend
  auto_profile_log: true
  # Allowed values: gen_vg, bus_vm, auto, strict_check
  pv_voltage_source: gen_vg
  pv_voltage_mismatch_tol_pu: 1.0e-4
  # Allowed values: bus_vm, gen_vg, imported_setpoint, hybrid
  compare_voltage_reference: imported_setpoint
  # Allowed values: admittance, voltage_dependent_injection
  bus_shunt_model: admittance
  # Allowed values: deg, rad
  shift_unit: deg
  # Typical values: 1.0 (standard), -1.0 (opposite sign convention)
  shift_sign: 1.0
  # Allowed values: normal, reciprocal
  ratio: normal
  enable_pq_gen_controllers: true
  # Allowed values: off, on, auto
  preallocate_network: auto
  preallocate_min_buses: 500

performance:
  enabled: true
  # Allowed values: off, summary, iteration, full
  level: iteration
  print_to_console: true
  write_to_logfile: true
  show_allocations: false
  show_iteration_table: true
  compact_logging: true
  representative_warmup_runs: 0
  compare_cold_warm: false
  skip_reference_comparison: false
  skip_expensive_diagnostics: true
  skip_branch_neighborhood_report: true
  max_diagnostic_rows: 25

runtime:
  print_thread_config: true
  # keep = keep current process setting.
  julia_threads: keep  # requires process startup or script re-exec
  blas_threads: keep   # can be applied at runtime

diagnostics:
  log_effective_config: false
  console_summary: true
  # Allowed values: off, compact, full
  console_auto_profile: compact
  # Allowed values: off, compact, summary, full
  console_diagnostics: compact
  # Allowed values: off, summary, full
  console_q_limit_events: summary
  console_max_rows: 20
  # Allowed values: off, compact, full
  logfile_diagnostics: full

output:
  console_summary: true
  # Allowed values: off, compact, full
  console_auto_profile: compact
  # Allowed values: off, compact, summary, full
  console_diagnostics: compact
  # Allowed values: off, summary, full
  console_q_limit_events: summary
  console_max_rows: 20
  # Allowed values: off, compact, classic, full
  logfile_results: full
  result_table_max_rows: 200
  result_table_large_case_threshold_buses: 1000
  # Allowed values: summary, classic, full
  result_table_large_case_mode: summary
  # Allowed values: off, compact, full
  logfile_diagnostics: full
  # Allowed values: off, compact, full
  logfile_performance: full
  # Allowed values: off, summary, table, full
  logfile_warnings: full

benchmark:
  enabled: true
  # Allowed values: rectangular
  methods: [rectangular]
  seconds: 2.0
  samples: 50
  show_once: false
  # Allowed values: classic, dataframe, compact
  show_once_output: classic
  # 0 disables node-count limit for one-shot output.
  show_once_max_nodes: 0

control:
  # Enable the generic outer-loop control framework.
  # If a network contains registered controllers, high-level runners such as
  # run_sparlectra(net=...) can use run_control! around the inner runpf! solver.
  enabled: true
  # Global maximum number of outer controller iterations.
  # This is independent from power_flow.max_iter, which limits the inner
  # Newton / power-flow iterations.
  max_outer_iterations: 20
  # Collect machine-readable control trace rows in ControlRunResult.trace.
  trace: true
  # Reserved for future or implementation-dependent per-iteration control logging.
  log_iterations: true
  # Stop outer-loop orchestration if the inner power flow fails.
  stop_on_pf_failure: true
  # Reserved for future YAML-based controller instantiation.
  # Leave this empty for now.
  # Transformer controllers are currently added programmatically via
  # addTapController! or addPowerTransformerControl!.
  controllers: []

extensions:
  # Reserved for future extension schemas.
  reserved: true
