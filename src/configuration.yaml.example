# Sparlectra central default configuration.
#
# Copy this file to examples/configuration.yaml for local user overrides.
# The local override file is intentionally ignored by Git.

power_flow:
  # Allowed values: rectangular
  # Rectangular is the supported public AC power-flow path.
  method: rectangular
  # Selects which solver actually computes the power-flow solution.
  # Allowed values: rectangular, apslf
  # - rectangular: the internal Newton-Raphson solver (rectangular_network_solver.jl).
  # - apslf: the AnalyticLoadFlow.jl-backed analytic power-series solver (ApslfSolver);
  #   requires the optional AnalyticLoadFlow.jl dependency to be loaded.
  solver: rectangular
  # Options for solver: apslf.
  apslf:
    # Highest power-series coefficient to compute.
    order: 40
    # Evaluate the voltage series via Pade [L/M] approximants instead of direct Taylor summation.
    use_pade: true
    # Run a Newton-Raphson polishing step on the series result.
    nr_polish: true
  # Use the APSLF solver as a start-value generator ahead of the rectangular
  # Newton-Raphson solve. Incompatible with solver: apslf (start generator is
  # only meaningful ahead of NR). No use_pade/nr_polish here: polishing is left
  # to the downstream NR solve (nr_polish=false internally).
  apslf_start:
    enabled: false
    order: 40
  # Legacy start switch (true = synthetic flat start). Keep aligned with start_mode below.
  flatstart: true
  # Positive solver tolerance and iteration cap.
  tol: 1.0e-5
  max_iter: 80
  # Automatic damping for difficult cases.
  autodamp: true
  autodamp_min: 0.05
  # Wrong-branch plausibility checks after numerical convergence.
  # Allowed values: off, warn, fail, rescue
  wrong_branch_detection: warn
  # Modes:
  # - off: disable post-convergence plausibility checks
  # - warn: keep converged PF result, but report suspicious branch-quality metadata
  # - fail: treat suspicious converged result as PF failure
  # - rescue: reserved mode; currently reports "rescue requested but not available"
  #   and does not run retry attempts yet
  wrong_branch_rescue: false
  wrong_branch_min_vm_pu: 0.70
  wrong_branch_max_vm_pu: 1.30
  wrong_branch_max_angle_spread_deg: 180.0
  # Maximum allowed absolute angle difference across active branches (degrees).
  wrong_branch_max_branch_angle_deg: 90.0
  wrong_branch_min_low_vm_count: 1
  wrong_branch_rescue_max_attempts: 2

  # Rectangular workspace handling.
  rectangular_workspace_reuse: true
  # Allowed values: off, on, auto
  rectangular_preallocate_workspace: auto
  rectangular_workspace_min_buses: 1000

  # AC island diagnostic artifacts.
  islands:
    enabled: true
    # Allowed values: solve_independent
    mode: solve_independent
    # Allowed values: matpower_like
    reference_policy: matpower_like
    diagnostic_continue_after_failure: true

  # Start projection and warmstart controls.
  start_mode:
    # Allowed values: classic, dc, bus_va_blend, matpower_va
    angle_mode: dc
    # Allowed values: classic, pv_gen_vg, pv_bus_vm, all_bus_vm, profile_blend
    # To use imported MATPOWER reference values, keep profile_blend with profile_source: matpower_reference.
    voltage_mode: profile_blend
    # Allowed values: flat, dc, bus_metadata, historical_profile, matpower_reference, state_estimation, scada_snapshot
    profile_source: matpower_reference
    # Enable projection-based candidate selection instead of direct start.
    start_projection: true
    # Try a DC-angle candidate start.
    try_dc_start: true
    # Scan blend_lambdas as additional candidates.
    try_blend_scan: true
    # Apply branch sanity checks to candidate starts.
    branch_guard: true
    # Measure/score candidate starts before selection.
    measure_candidates: true
    # Accept DC start even without candidate measurements.
    accept_unmeasured_dc_start: false
    # Unconditionally run a full standalone DC power flow first and seed the
    # rectangular Newton-Raphson solve's start angles from it (voltage
    # magnitudes are not affected: the DC model has no voltage-magnitude
    # solution, so Slack/PV setpoints and the usual voltage_mode still apply).
    # Bypasses the angle_mode/try_dc_start/measure_candidates candidate
    # selection above entirely -- no quality gate, matching rundcpf!'s
    # seed_ac_start=true behavior. Mutually exclusive with
    # power_flow.apslf_start.enabled and power_flow.solver in (apslf, dc).
    dc_seed_unconditional: false
    # Reuse imported MATPOWER reference values during start generation.
    reuse_import_data: true
    # Candidate blend factors used when try_blend_scan=true.
    blend_lambdas: [0.25, 0.5, 0.75]
    # Positive DC-angle clamp in degrees.
    dc_angle_limit_deg: 60.0

  # Optional guarded current-injection pre-solve after start modes and before NR.
  start_current_iteration:
    enabled: false
    max_iter: 10
    tol: 1.0e-3
    damping: 0.5
    accept_only_if_improved: true
    min_improvement_factor: 0.98
    vm_min_pu: 0.5
    vm_max_pu: 1.5
    max_angle_step_deg: 30.0
    only_for_large_cases: false

  # Optional Armijo merit-function line search inside the autodamp backtracking
  # loop. enabled=false (default) leaves today's max-mismatch autodamp behavior
  # unchanged. enabled=true requires autodamp=true (validation error otherwise).
  merit:
    enabled: false
    # Sufficient-decrease constant, must be in (0, 0.5).
    armijo_c1: 1.0e-4
    # Diagonal scaling weights for P/Q/voltage residuals (positive reals).
    scale_p: 1.0
    scale_q: 1.0
    scale_v: 1.0
    # true = fall back to the max-mismatch criterion if no trial satisfies Armijo;
    # false = fall back to the most conservative finite trial (today's autodamp fallback).
    fallback_max_mismatch: true

  # Optional scaled-Newton trust-region step control: an alternative to
  # autodamp that caps the Newton step norm at an adaptive radius and
  # accepts/rejects steps by merit decrease. enabled=false (default) leaves
  # the solver unchanged. Mutually exclusive with autodamp=true (validation
  # error otherwise).
  trust_region:
    enabled: false
    # Initial trust-region radius, in per-unit state-vector (2-)norm.
    initial_radius: 1.0
    # Radius floor; falling below it declares non-convergence
    # (reason = :trust_region_collapsed) instead of looping forever.
    min_radius: 1.0e-4
    # Radius ceiling.
    max_radius: 10.0
    # Minimum actual/predicted reduction ratio (rho) required to accept a step.
    eta_accept: 0.1
    # Radius multiplier on a rejected step, in (0, 1).
    shrink_factor: 0.5
    # Radius multiplier on a strongly successful boundary step, > 1.
    expand_factor: 2.0
    # rho threshold (in (0, 1)) above which a boundary-hitting accepted step expands the radius.
    expand_threshold: 0.75
    # scaled: rescale the full Newton direction to the radius (default, unchanged
    # behavior). dogleg: blend the Newton direction with a steepest-descent
    # (Cauchy) step when the radius shrinks below the Newton step norm.
    step_mode: scaled

  # Reactive-power limit switching.
  qlimits:
    enabled: true

    # Q-limit enforcement strategy.
    # Allowed values:
    # - active_set: dynamic in-iteration PV/PQ switching
    # - classic_simultaneous: classical outer loop; solve the base PF first,
    #   then switch all Q-limit violations after successful convergence
    # - classic_one_at_a_time: classical outer loop; solve the base PF first,
    #   then switch the largest Q-limit violation per outer-loop pass
    #
    # Legacy aliases still accepted for old YAML files:
    # - matpower_simultaneous  -> classic_simultaneous
    # - matpower_one_at_a_time -> classic_one_at_a_time
    enforcement_mode: active_set

    # First iteration where Q-limit switching is allowed.
    # Classical outer-loop modes ignore in-iteration switching and check Q limits
    # only after a successful base PF.
    start_iter: 3
    # Allowed values: iteration, auto, iteration_or_auto
    start_mode: iteration_or_auto
    auto_q_delta_pu: 1.0e-4
    hysteresis_pu: 0.01
    cooldown_iters: 1
    # Optional bus-id filters for focused diagnostics/policies.
    trace_buses: []
    lock_pv_to_pq_buses: []
    guard:
      enabled: true
      min_q_range_pu: 0.02
      # Allowed values: prefer_pq, lock_pq
      narrow_range_mode: lock_pq
      # Allowed values: lock_pq
      zero_range_mode: lock_pq
      # Allowed values: delayed_switch, lock_pq
      violation_mode: lock_pq
      violation_threshold_pu: 1.0e-4
      max_switches: 3
      max_remaining_violations: 0
      accept_bounded_violations: false
      freeze_after_repeated_switching: true
      log: true

state_estimation:
  enabled: true
  # Allowed values: wls
  method: wls
  tol: 1.0e-8
  max_iter: 20
  # Flat start for state-estimation initialization.
  flatstart: true
  jac_eps: 1.0e-6
  update_net: true
  observability:
    enabled: true

matpower_import:
  # MATPOWER case filename/path resolved by single-case runner paths.
  case: case14.m
  # Ordered batch list for run_sparlectra_cases; non-empty cases take precedence over case.
  cases: [case14.m, case118.m]
  # Allowed values: off, recommend, apply
  # recommend prints a pre-run table without changing the active run.
  # apply may change only convention settings with clear residual evidence;
  # user YAML files are never rewritten.
  auto_profile: recommend
  auto_profile_log: true
  # Allowed values: gen_vg, bus_vm, auto, strict_check
  pv_voltage_source: gen_vg
  pv_voltage_mismatch_tol_pu: 1.0e-4
  # Allowed values: bus_vm, gen_vg, imported_setpoint, hybrid
  compare_voltage_reference: imported_setpoint
  # Allowed values: admittance, voltage_dependent_injection
  bus_shunt_model: admittance
  # Allowed values: deg, rad
  shift_unit: deg
  # Typical values: 1.0 (standard), -1.0 (opposite sign convention)
  shift_sign: 1.0
  # Allowed values: normal, reciprocal
  ratio: normal
  enable_pq_gen_controllers: true
  # Allowed values: off, on, auto
  preallocate_network: auto
  preallocate_min_buses: 500
  apply_bus_names: false
  apply_branch_names: false
  apply_branch_kind: false
  import_for001_contingencies: true
  # Allowed values: reject_active, ignore_inactive, pf_injections
  matpower_dcline_mode: pf_injections

transformer:
  # Tap-changer model used by all network importers (MATPOWER and native DTF).
  # Allowed values: ideal, impedance_correction
  # - ideal: tap steps only change the complex winding ratio; transformer R/X
  #   keep their neutral-position values (no impedance feedback).
  # - impedance_correction: tap steps re-refer the transformer series impedance
  #   through the tapped winding; R and X are scaled with |1 + f*e^(j*phi)|^2.
  tap_changer_model: ideal

matpower_export:
  # Whether writeMatpowerCasefile writes the solved AC power-flow state back
  # into the exported case.
  # - true (default): bus VM/VA reflect the solved node state, and mpc.branch
  #   gains the standard MATPOWER result columns 14-17 (PF, QF, PT, QT) sourced
  #   from the existing branch-flow report path. A
  #   mpc.sparlectra.solution_written = 1 marker documents this. If the network
  #   has not been solved, the exporter warns and falls back to the 13-column
  #   model-only export.
  # - false: pure model file. mpc.branch keeps its historical 13 columns, and
  #   VM = 1.0 / VA = 0.0 for all non-slack/non-PV buses (slack and PV
  #   setpoints are preserved).
  write_solution: true

performance:
  enabled: true
  # Allowed values: off, summary, iteration, full
  level: iteration
  print_to_console: true
  write_to_logfile: true
  show_allocations: false
  show_iteration_table: true
  compact_logging: true
  representative_warmup_runs: 0
  compare_cold_warm: false
  skip_reference_comparison: false
  skip_expensive_diagnostics: true
  skip_branch_neighborhood_report: true
  max_diagnostic_rows: 25

runtime:
  print_thread_config: true
  # keep = keep current process setting.
  julia_threads: keep  # requires process startup or script re-exec
  blas_threads: keep   # can be applied at runtime
  # Runtime case fields are populated in API/Web UI effective_config.yaml artifacts.
  casefile: ""
  case_name: ""
  case_source: ""
  configured_default_casefile: ""

diagnostics:
  log_effective_config: false
  console_summary: true
  # Allowed values: off, compact, full
  console_auto_profile: compact
  # Allowed values: off, compact, summary, full
  console_diagnostics: compact
  # Allowed values: off, summary, full
  console_q_limit_events: summary
  console_max_rows: 100
  # Allowed values: off, compact, full
  logfile_diagnostics: compact

output:
  console_summary: true
  # Allowed values: off, compact, full
  console_auto_profile: compact
  # Allowed values: off, compact, summary, full
  console_diagnostics: compact
  # Allowed values: off, summary, full
  console_q_limit_events: summary
  console_max_rows: 100
  # Allowed values: off, compact, classic, full
  logfile_results: full
  result_table_max_rows: 200
  result_table_large_case_threshold_buses: 1000
  # Allowed values: summary, classic, full
  result_table_large_case_mode: summary
  # Detailed CSV artifacts use buffered writing for normal cases and streaming
  # for very large cases by default.
  # Allowed values: auto, buffered, streaming
  detailed_result_csv_write_mode: auto
  # Allowed values: auto, report, direct
  detailed_result_csv_exporter: auto
  detailed_result_csv_direct_threshold_buses: 10000
  detailed_result_csv_buffer_initial_bytes: 8388608
  detailed_result_csv_buffer_max_bytes: 67108864
  detailed_result_csv_streaming_threshold_rows: 100000
  # Allowed values: off, compact, full
  logfile_diagnostics: compact
  # Allowed values: off, compact, full
  logfile_performance: full
  # Allowed values: off, summary, table, full
  logfile_warnings: full

benchmark:
  enabled: true
  # Allowed values: rectangular
  methods: [rectangular]
  seconds: 2.0
  samples: 50
  show_once: false
  # Allowed values: classic, dataframe, compact
  show_once_output: classic
  # 0 disables node-count limit for one-shot output.
  show_once_max_nodes: 0

control:
  # Enable the generic outer-loop control framework.
  # If a network contains registered controllers, high-level runners such as
  # run_sparlectra(net=...) can use run_control! around the inner runpf! solver.
  enabled: true
  # Global maximum number of outer controller iterations.
  # This is independent from power_flow.max_iter, which limits the inner
  # Newton / power-flow iterations.
  max_outer_iterations: 20
  # Collect machine-readable control trace rows in ControlRunResult.trace.
  trace: true
  # Reserved for future or implementation-dependent per-iteration control logging.
  log_iterations: true
  # Stop outer-loop orchestration if the inner power flow fails.
  stop_on_pf_failure: true
  # Reserved for future YAML-based controller instantiation.
  # Leave this empty for now.
  # Transformer controllers are currently added programmatically via
  # addTapController! or addPowerTransformerControl!.
  controllers: []

webui:
  # Show the "Case-specific settings loaded from ..." notice on the Web UI
  # PowerFlow form whenever the selected case has a saved settings profile
  # (a .sparlectra-webui.yaml sidecar). Set to false once you know a case has
  # saved settings and no longer want the reminder.
  show_case_settings_notice: true

extensions:
  # Reserved for future extension schemas.
  reserved: true
