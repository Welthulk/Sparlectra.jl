# Focused ACTIVSg10k rectangular NR Q-limit trace for BUS_I 40712.
# Usage:
#   SPARLECTRA_MATPOWER_IMPORT_YAML=src/examples/matpower_import_activsg10k_qlimit_trace.yaml.example julia --project=. src/examples/matpower_import.jl
case: case_ACTIVSg10k.m
methods: [rectangular]

opt_fd: false
opt_sparse: true
opt_flatstart: true
flatstart_angle_mode: dc
flatstart_voltage_mode: bus_vm_va_blend

matpower_pv_voltage_source: gen_vg
compare_voltage_reference: hybrid
ignore_q_limits: false
qlimit_start_iter: 3
qlimit_start_mode: auto_q_delta
q_hyst_pu: 0.05
qlimit_trace_buses: [40712]

diagnose_pv_voltage_references: true
diagnose_matpower_reference: true
verbose: 1
show_once: true
benchmark: false
