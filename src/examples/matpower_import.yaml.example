#
# Example configuration for src/examples/matpower_import.jl
#
# Local developer usage (VS Code "Run Julia File"):
#   copy this file to `matpower_import.yaml` and edit as needed.
#
# CLI usage:
#   julia --project=. src/examples/matpower_import.jl src/examples/matpower_import.yaml
# or
#   SPARLECTRA_MATPOWER_IMPORT_YAML=src/examples/matpower_import.yaml julia --project=. src/examples/matpower_import.jl
#
# Purpose of this example:
# 1. Provide a compact, documented baseline for MATPOWER import tests.
# 2. Keep option order aligned with `matpower_import.yaml`.
# 3. Avoid duplicate active YAML keys in the general section.
# 4. Put case-specific alternatives into the inactive override section at the bottom.
#

# ---------------------------------------------------------------------------
# Case selection
# ---------------------------------------------------------------------------

case: case118.m
#case: case300.m
#case: case1354pegase.m
#case: case2869pegase.m
#case: case9241pegase.m
#case: case_ACTIVSg10k.m
#case: case1951rte.m

methods: [rectangular]

# ---------------------------------------------------------------------------
# MATPOWER auto-profile / pre-run diagnostics
# ---------------------------------------------------------------------------

# false: keep current behavior.
# recommend: inspect the imported case and log recommended robust settings.
# apply: inspect the case and apply safe recommendations unless the YAML file
#       already sets that option explicitly.
matpower_auto_profile: false
matpower_auto_profile_log: true

# ---------------------------------------------------------------------------
# Solver / Newton-Raphson options
# ---------------------------------------------------------------------------

opt_fd: false
opt_sparse: true

# Set true for a pure flatstart run.
# Set false to use imported MATPOWER VM/VA values as initial values where available.
opt_flatstart: true

# Newton solver controls.
tol: 1.0e-8
max_ite: 30
verbose: 1

# Set `autodamp: true` for difficult flat-start cases or large MATPOWER
# networks where a full Newton step can increase the mismatch.
autodamp: true
autodamp_min: 0.05

# ---------------------------------------------------------------------------
# Reference / slack-bus voltage handling
# ---------------------------------------------------------------------------

# By default, the slack-bus VM/VA read from the MATPOWER file is preserved.
# Set reference_override: true to replace it with the values below.
reference_override: false
reference_vm_pu: 1.0
reference_va_deg: 0.0

# ---------------------------------------------------------------------------
# Bus shunt modeling
# ---------------------------------------------------------------------------

# Bus shunt modeling:
# - admittance: classic MATPOWER treatment, stamp Gs/Bs into the Y-bus diagonal.
# - voltage_dependent_injection: keep Gs/Bs out of Y-bus and include their
#   |V|^2-dependent power contribution in the nonlinear injection/mismatch path.
bus_shunt_model: admittance

# ---------------------------------------------------------------------------
# Start projection / flatstart robustness
# ---------------------------------------------------------------------------

# Optional start projection before rectangular NR.
# Recommended for difficult flatstart cases.
start_projection: false
start_projection_try_dc_start: false
start_projection_try_blend_scan: false
start_projection_blend_lambdas: [0.1, 0.25, 0.5, 0.75]
start_projection_dc_angle_limit_deg: 70.0

# Flatstart robustness options for difficult large MATPOWER cases.
# Recommended diagnostic rescue seed:
#   flatstart_angle_mode: dc
#   flatstart_voltage_mode: bus_vm_va_blend
flatstart_angle_mode: dc
flatstart_voltage_mode: bus_vm_va_blend

flatstart_branch_guard: true
flatstart_min_vm_pu: 0.5
flatstart_max_angle_step_deg: 20.0
flatstart_max_vm_step_pu: 0.1

# Wrong-branch detection and optional rescue.
wrong_branch_detection: false
wrong_branch_min_vm_pu: 0.4
wrong_branch_max_angle_spread_deg: 120.0
wrong_branch_rescue: false
wrong_branch_rescue_modes: [dc, bus_vm_va_blend, matpower_va]

# ---------------------------------------------------------------------------
# PV -> PQ Q-limit switching
# ---------------------------------------------------------------------------

# Q-limit / PV->PQ behavior:
# - If true, all PV buses are locked against PV->PQ switching.
#   This effectively ignores reactive-power limits during the solve.
ignore_q_limits: false

# Fine-grained manual locks (MATPOWER/original bus IDs).
# Applied when ignore_q_limits=false.
lock_pv_to_pq_buses: []

# PV->PQ Q-limit switching start controls:
# - qlimit_start_mode: iteration, auto_q_delta, or iteration_or_auto.
# - iteration starts switching at qlimit_start_iter.
# - auto_q_delta starts once PV reactive-power request changes are <= qlimit_auto_q_delta_pu.
qlimit_start_iter: 3
qlimit_start_mode: iteration
qlimit_auto_q_delta_pu: 1.0e-4

# Optional Q-limit violation guard:
# - delayed_switch preserves the hysteresis-gated PV->PQ switching behavior.
# - lock_pq immediately locks active PV buses whose calculated Q violates a
#   finite Qmin/Qmax by more than qlimit_guard_violation_threshold_pu at an
#   eligible Q-limit check.
qlimit_guard_violation_mode: delayed_switch
qlimit_guard_violation_threshold_pu: 1.0e-4

# Hysteresis/cooldown for PV<->PQ switching.
q_hyst_pu: 0.01
cooldown_iters: 1

# Optional focused Q-limit decision trace.
# Entries are MATPOWER BUS_I values when available.
qlimit_trace_buses: []

# ---------------------------------------------------------------------------
# MATPOWER PV/REF voltage-reference handling
# ---------------------------------------------------------------------------

# PV/REF voltage-reference handling:
# - BUS.VM is the stored MATPOWER bus-matrix voltage magnitude.
# - GEN.VG is the generator voltage setpoint normally used for PV/REF control.
# - If they differ, solving against GEN.VG while comparing against BUS.VM can
#   produce a false Vm comparison failure at PV/REF buses.
# matpower_pv_voltage_source: gen_vg, bus_vm, auto, or strict_check.
# compare_voltage_reference: bus_vm, gen_vg, imported_setpoint, or hybrid.
matpower_pv_voltage_source: gen_vg
matpower_pv_voltage_mismatch_tol_pu: 1.0e-4
compare_voltage_reference: imported_setpoint

# ---------------------------------------------------------------------------
# MATPOWER branch SHIFT/TAP convention controls
# ---------------------------------------------------------------------------

# MATPOWER branch SHIFT/TAP convention controls:
# - deg/sign=1 preserves MATPOWER default SHIFT semantics (degrees on from side).
# - matpower_ratio=normal preserves MATPOWER TAP as stored.
# - matpower_ratio=reciprocal imports 1/TAP.
# - Some PEGASE-style files use small radian-like SHIFT values and may need sign=-1.
matpower_shift_unit: deg
matpower_shift_sign: 1.0
matpower_ratio: normal

# ---------------------------------------------------------------------------
# Optional MATPOWER import behavior
# ---------------------------------------------------------------------------

# Optional MATPOWER import behavior for PQ-type generators:
# - If true, PQ generators get constant P(U)/Q(U) controllers based on MATPOWER limits.
# - Applied only for generators connected to MATPOWER PQ buses (BUS_TYPE=1).
# - If false, import keeps the plain generator values without creating these controllers.
enable_pq_gen_controllers: false

# Legacy warning tracing:
# - If true, legacy busType warnings include caller=<file>:<line>.
# - Helpful to identify remaining code paths that still call addBus!(... busType=...)
#   or setBusType! during import/solver runs.
trace_legacy_bus_type_warnings: false

# ---------------------------------------------------------------------------
# MATPOWER comparison controls
# ---------------------------------------------------------------------------

show_diff: true

# Practical compare tolerances for the current general test run.
tol_vm: 0.02
tol_va: 1.0

# ---------------------------------------------------------------------------
# Diagnostics
# ---------------------------------------------------------------------------

# If true, write the effective parsed YAML/options to the logfile.
log_effective_config: true

# MATPOWER-reference diagnostics:
# - diagnose_matpower_reference prints the largest residuals obtained when the
#   VM/VA values embedded in the MATPOWER data are evaluated against the imported
#   network equations. Large residuals mean the reference VM/VA is not an exact
#   solution of the imported data/model before the Sparlectra solve is considered.
# - diagnose_branch_shift_conventions scans common phase-shift interpretations.
diagnose_matpower_reference: true
diagnose_branch_shift_conventions: false
diagnose_negative_branch_impedances: true

# PV voltage-reference diagnostics.
diagnose_pv_voltage_references: true
diagnose_pv_voltage_maxlines: 30

# Optional logfile-only neighborhood and residual-cluster diagnostics.
diagnose_branch_neighborhood: false
diagnose_branch_neighborhood_buses: []
diagnose_branch_neighborhood_depth: 1
diagnose_branch_neighborhood_maxlines: 200

diagnose_residual_clusters: false
diagnose_residual_cluster_threshold_mw: 1.0
diagnose_residual_cluster_maxlines: 20

diagnose_maxlines: 12

# ---------------------------------------------------------------------------
# Benchmark / output controls
# ---------------------------------------------------------------------------

# Console/logfile routing:
# - Console defaults to compact operational summaries for large cases.
# - Detailed diagnostics and tables remain in the logfile.
console_summary: true
console_auto_profile: compact
console_diagnostics: compact
console_q_limit_events: summary
console_max_rows: 20
logfile_diagnostics: full

# Set `benchmark: false` to only run `show_once` and write logfile/results once.
# Useful for large cases where benchmarking can take very long.
benchmark: false
seconds: 2.0
samples: 50

# Single result/log run.
show_once: true

# show_once output mode:
# - classic: full classic result tables (printACPFlowResults)
# - dataframe: compact DataFrame-style node table
show_once_output: dataframe

# Limits only DataFrame-style output (0 = all nodes); ignored for classic output.
show_once_max_nodes: 30
show_once_max_pv_rows: 30

# ---------------------------------------------------------------------------
# Special-case override section
# ---------------------------------------------------------------------------
# Keep this section at the bottom. To activate a special case, uncomment the
# corresponding block. Values here intentionally override the general settings
# above because YAML readers usually keep the last value for duplicate keys.
#
# --- case1951rte flatstart comparison ---
#case: case1951rte.m
#opt_flatstart: true
#tol: 1.0e-8
#max_ite: 50
#autodamp: true
#autodamp_min: 0.05
#compare_voltage_reference: hybrid
#tol_vm: 0.01
#tol_va: 2.0
#enable_pq_gen_controllers: true
#qlimit_start_iter: 5
#qlimit_start_mode: auto_q_delta
#qlimit_auto_q_delta_pu: 0.02
#q_hyst_pu: 0.06
#cooldown_iters: 3
#diagnose_matpower_reference: true
#diagnose_branch_shift_conventions: true
#diagnose_negative_branch_impedances: true
#
# --- ACTIVSg10k flatstart / wrong-branch rescue ---
#case: case_ACTIVSg10k.m
#opt_flatstart: true
#flatstart_angle_mode: dc
#flatstart_voltage_mode: bus_vm_va_blend
#start_projection: true
#start_projection_try_blend_scan: false
#start_projection_try_dc_start: true
#max_ite: 80
#tol: 1.0e-5
#tol_vm: 0.2
#tol_va: 2.0
#qlimit_start_iter: 3
#qlimit_start_mode: auto_q_delta
#qlimit_auto_q_delta_pu: 0.01
#q_hyst_pu: 0.15
#cooldown_iters: 2
#
# --- PEGASE-style SHIFT/radian experiment ---
#case: case1354pegase.m
#matpower_shift_sign: -1.0
#matpower_shift_unit: rad
#matpower_ratio: normal
#diagnose_matpower_reference: true
#diagnose_branch_shift_conventions: true
#
# --- MATPOWER warmstart validation ---
# --- Strict MATPOWER warmstart validation ---
#opt_flatstart: false
#start_projection: false
#wrong_branch_detection: false
#wrong_branch_rescue: false
#tol: 1.0e-10
#max_ite: 20
#compare_voltage_reference: imported_setpoint
#tol_vm: 1.0e-5
#tol_va: 0.05

# --- Robust flatstart variant for harder cases ---
#start_projection: true
#start_projection_try_dc_start: true
#flatstart_angle_mode: dc
#flatstart_voltage_mode: bus_vm_va_blend
#wrong_branch_detection: true
#wrong_branch_rescue: true
#tol: 1.0e-6
#tol_vm: 0.01
#tol_va: 2.0
