#
# Example configuration for src/examples/matpower_import.jl
#
# Local developer usage (VS Code "Run Julia File"):
#   copy this file to `matpower_import.yaml` and edit as needed.
#
# CLI usage:
#   julia --project=. src/examples/matpower_import.jl src/examples/matpower_import.yaml
# or
#   SPARLECTRA_MATPOWER_IMPORT_YAML=src/examples/matpower_import.yaml julia --project=. src/examples/matpower_import.jl
#
case: case118.m
methods: [rectangular]

# Solver/NR options
opt_fd: false
opt_sparse: true
# If true, PQ-bus magnitudes and all voltage angles start flat while slack/PV
# voltage magnitudes from MATPOWER remain active setpoints. Keep false when you
# intentionally want to restart from the stored MATPOWER VM/VA solution.
opt_flatstart: false

# Bus shunt modeling:
# - admittance: classic MATPOWER treatment, stamp Gs/Bs into the Y-bus diagonal.
# - voltage_dependent_injection: keep Gs/Bs out of Y-bus and include their
#   |V|^2-dependent power contribution in the nonlinear injection/mismatch path.
bus_shunt_model: admittance

# Set `autodamp: true` for difficult flat-start cases such as larger MATPOWER
# networks where a full Newton step increases the mismatch.
autodamp: false
autodamp_min: 1.0e-3

# Optional start projection before rectangular NR / external solver starts.
start_projection: false
start_projection_try_dc_start: true
start_projection_try_blend_scan: true
start_projection_blend_lambdas: [0.25, 0.5, 0.75]
start_projection_dc_angle_limit_deg: 60.0
max_ite: 30
tol: 1.0e-6
verbose: 1
cooldown_iters: 0
q_hyst_pu: 0.0

# PV->PQ Q-limit switching start controls:
# - qlimit_start_mode: iteration, auto_q_delta, or iteration_or_auto.
# - iteration starts switching at qlimit_start_iter (default preserves previous iteration 2 behavior).
# - auto_q_delta starts once PV reactive-power request changes are <= qlimit_auto_q_delta_pu.
qlimit_start_iter: 3
qlimit_start_mode: iteration
qlimit_auto_q_delta_pu: 1.0e-4

# MATPOWER comparison controls
show_diff: true
tol_vm: 0.02
tol_va: 0.5

# Q-limit / PV->PQ behavior:
# - If true, all PV buses are locked against PV->PQ switching.
#   This effectively ignores reactive-power limits during the solve.
ignore_q_limits: false

# Optional MATPOWER import behavior for PQ-type generators:
# - If true, PQ generators get constant P(U)/Q(U) controllers based on MATPOWER limits.
# - Applied only for generators connected to MATPOWER PQ buses (BUS_TYPE=1).
# - If false, import keeps the plain generator values without creating these controllers.
#   Keep enabled by default for compatibility with previous convergence behavior.
enable_pq_gen_controllers: false

# Legacy warning tracing:
# - If true, legacy busType warnings include caller=<file>:<line>.
# - Helpful to identify remaining code paths that still call addBus!(... busType=...)
#   or setBusType! during import/solver runs.
trace_legacy_bus_type_warnings: false
# - Fine-grained manual locks (MATPOWER/original bus IDs). Applied when ignore_q_limits=false.
lock_pv_to_pq_buses: []

# Benchmark controls
# - Set `benchmark: false` to only run `show_once` and write logfile/results once.
#   Useful for large cases (e.g. case1951rte / case2869pegase) where benchmarking can take very long.
benchmark: false
seconds: 2.0
samples: 50
#show_once: true
show_once: true
# show_once output mode:
# - classic: full classic result tables (printACPFlowResults)
# - dataframe: compact DataFrame-style node table
#show_once_output: classic
show_once_output: dataframe
# Limits only DataFrame-style output (0 = all nodes); ignored for classic output.
show_once_max_nodes: 30
